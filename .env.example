# ─────────────────────────────────────────────────────
# Quantum-Enhanced Threat Intelligence — Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# VirusTotal API key (get from https://www.virustotal.com)
VT_API_KEY=

# Model directory (relative to project root)
MODEL_DIR=models

# Quantum model directory
QUANTUM_MODEL_DIR=phase4/models

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Scanner settings
MAX_FILE_SIZE_MB=100
CONFIDENCE_THRESHOLD=0.60
MALWARE_THRESHOLD=0.50
